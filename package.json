{
  "name": "sixtyeight",
  "version": "1.0.0",
  "license": "MIT",
  "description": "A text based user interface to the 68K Macintosh serial diagnostics",
  "author": "Nick Melnick <nrmelnick@gmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "pkg": "node node_modules/.bin/pkg ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/node": "^26.1.1",
    "@yao-pkg/pkg": "^6.21.0",
    "eslint": "^10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@serialport/bindings-interface": "^1.2.2",
    "blessed": "^0.1.81",
    "serialport": "^13.0.0"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "node_modules/@serialport/bindings-cpp/prebuilds"
    ],
    "targets": [
      "node24-linux-x64"
    ],
    "outputPath": "pkg"
  }
}
